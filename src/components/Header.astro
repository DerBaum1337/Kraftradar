---
import Markenlogo from './Markenlogo.astro';

const navigation = [
	{ href: '/', label: 'Start' },
	{ href: '/training', label: 'Training' },
	{ href: '/supplements', label: 'Supplements' },
	{ href: '/gym-zubehoer', label: 'Gym-Zubehör' },
	{ href: '/mein-weg', label: 'Mein Weg' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const isActive = (href: string) =>
	href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header class="site-header">
	<a class="site-logo" href="/" aria-label="KraftRadar Startseite">
		<Markenlogo />
	</a>

	<button
		class="menu-toggle"
		type="button"
		aria-label="Hauptnavigation öffnen"
		aria-controls="hauptnavigation"
		aria-expanded="false"
	>
		<span class="menu-toggle-lines" aria-hidden="true"></span>
		<span>Menü</span>
	</button>

	<nav id="hauptnavigation" aria-label="Hauptnavigation">
		<ul>
			{
				navigation.map((item) => (
					<li>
						<a
							href={item.href}
							aria-current={isActive(item.href) ? 'page' : undefined}
						>
							{item.label}
						</a>
					</li>
				))
			}
		</ul>
	</nav>
</header>

<script>
	const header = document.querySelector<HTMLElement>('.site-header');
	const toggle = document.querySelector<HTMLButtonElement>('.menu-toggle');

	toggle?.addEventListener('click', () => {
		const isOpen = header?.classList.toggle('site-header--menu-open') ?? false;
		toggle.setAttribute('aria-expanded', String(isOpen));
		toggle.setAttribute(
			'aria-label',
			isOpen ? 'Hauptnavigation schließen' : 'Hauptnavigation öffnen',
		);
	});
</script>
