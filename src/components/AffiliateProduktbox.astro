---
interface Props {
	url: string;
	productName: string;
}

const { url, productName } = Astro.props;
---

<aside class="affiliate-product-box" aria-label={`Werbung: ${productName}`}>
	<p class="affiliate-product-box__label">Werbung / Affiliate-Link</p>
	<h2>{productName} bei HSN</h2>
	<p>
		Wenn du über diesen Link kaufst, kann ich eine Provision erhalten. Für dich bleibt der Preis gleich.
	</p>
	<a class="button affiliate-product-box__button" href={url} target="_blank" rel="sponsored noopener noreferrer" aria-label={`${productName} bei HSN ansehen (öffnet in einem neuen Tab)`}>
		Bei HSN ansehen <span aria-hidden="true">↗</span>
	</a>
</aside>
