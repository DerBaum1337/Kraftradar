---
interface Props {
	href: string;
	category: string;
	title: string;
	description: string;
	linkLabel?: string;
	image?: string;
	imageAlt?: string;
	publishedAt?: Date;
	estimatedReadingMinutes?: number;
}

const {
	href,
	category,
	title,
	description,
	linkLabel = 'Weiterlesen',
	image,
	imageAlt = '',
	publishedAt,
	estimatedReadingMinutes,
} = Astro.props;

const meta = [
	publishedAt?.toLocaleDateString('de-DE', { month: 'long', year: 'numeric' }),
	estimatedReadingMinutes && `${estimatedReadingMinutes} Min. Lesezeit`,
].filter(Boolean);
---

<a class="article-card content-card" href={href}>
	{image && <img class="article-card-image" src={image} alt={imageAlt} loading="lazy" />}
	<span class="badge">{category}</span>
	<h3>{title}</h3>
	<p>{description}</p>
	{meta.length > 0 && <span class="article-card-meta">{meta.join(' · ')}</span>}
	<span class="card-link">{linkLabel} <span aria-hidden="true">→</span></span>
</a>
