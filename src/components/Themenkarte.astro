---
interface Props {
	bereich: string;
	titel: string;
	beschreibung: string;
	symbol?: string;
	status?: string;
	href?: string;
	linkText?: string;
}

const {
	bereich,
	titel,
	beschreibung,
	symbol,
	status,
	href,
	linkText = 'Mehr erfahren',
} = Astro.props;
---

{
	href ? (
		<a class="card topic-card topic-card--linked" href={href}>
			<div class="topic-card-header">
				{symbol && <span class="topic-card-symbol" aria-hidden="true">{symbol}</span>}
				<span class="badge">{bereich}</span>
			</div>
			<h3>{titel}</h3>
			<p>{beschreibung}</p>
			<span class="card-link">{linkText} <span aria-hidden="true">→</span></span>
		</a>
	) : (
		<article class="card topic-card topic-card--planned">
			<div class="topic-card-header">
				{symbol && <span class="topic-card-symbol" aria-hidden="true">{symbol}</span>}
				<span class="badge">{bereich}</span>
			</div>
			<h3>{titel}</h3>
			<p>{beschreibung}</p>
			{status && <span class="topic-card-status">{status}</span>}
		</article>
	)
}
