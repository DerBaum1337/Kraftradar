---
import Artikelkarte from './Artikelkarte.astro';
import { getArticlesByCategory, type ArtikelKategorie } from '../lib/artikel';
import { lesezeitInMinuten } from '../lib/lesezeit';

interface Props {
	category: ArtikelKategorie;
	heading: string;
	limit?: number;
}

const { category, heading, limit } = Astro.props;
const beitraege = await getArticlesByCategory(category);
const angezeigteBeitraege = limit ? beitraege.slice(0, limit) : beitraege;
---

{
	angezeigteBeitraege.length > 0 && (
		<section>
			<p class="eyebrow">Aktuelle Beiträge</p>
			<h2>{heading}</h2>
			<div class="card-grid">
				{angezeigteBeitraege.map((beitrag) => (
					<Artikelkarte
						href={`/${beitrag.data.category}/${beitrag.data.slug}`}
						category={beitrag.data.categoryLabel}
						title={beitrag.data.title}
						description={beitrag.data.excerpt}
						image={beitrag.data.heroImage?.src}
						imageAlt={beitrag.data.heroImage?.alt}
						publishedAt={beitrag.data.publishedAt}
						estimatedReadingMinutes={lesezeitInMinuten(beitrag.body ?? '')}
						linkLabel="Artikel lesen"
					/>
				))}
			</div>
		</section>
	)
}
