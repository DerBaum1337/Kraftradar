---
interface Source {
	title: string;
	publisher: string;
	url: string;
	accessedAt: string;
}

interface Props {
	sources: Source[];
}

const { sources } = Astro.props;
---

<section class="tool-sources" aria-labelledby="tool-quellen">
	<h2 id="tool-quellen">Quellen</h2>
	<ul class="tool-source-list">
		{sources.map((source) => (
			<li>
				<a href={source.url} target="_blank" rel="noopener noreferrer external">{source.title}</a>
				<span> · {source.publisher} · abgerufen am {source.accessedAt}</span>
			</li>
		))}
	</ul>
</section>
