---
import { render, type CollectionEntry } from 'astro:content';
import ArtikelLayout from '../../layouts/ArtikelLayout.astro';
import { getPublishedArticles } from '../../lib/artikel';

export async function getStaticPaths() {
	const entries = await getPublishedArticles();

	return entries.map((entry) => ({
		params: {
			bereich: entry.data.category,
			slug: entry.id,
		},
		props: { entry },
	}));
}

interface Props {
	entry: CollectionEntry<'artikel'>;
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---

<ArtikelLayout entry={entry} headings={headings}>
	<Content />
</ArtikelLayout>
