---
import { render, type CollectionEntry } from 'astro:content';
import ArtikelLayout from '../../layouts/ArtikelLayout.astro';
import { getArticlesByCategory, getPublishedArticles } from '../../lib/artikel';

export async function getStaticPaths() {
	const entries = await getPublishedArticles();

	return entries.map((entry) => ({
		params: {
			bereich: entry.data.category,
			slug: entry.id,
		},
		props: { entry },
	}));
}

interface Props {
	entry: CollectionEntry<'artikel'>;
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const relatedArticles = (await getArticlesByCategory(entry.data.category))
	.filter((article) => article.id !== entry.id)
	.slice(0, 2);
---

<ArtikelLayout entry={entry} headings={headings} relatedArticles={relatedArticles}>
	<Content />
</ArtikelLayout>
