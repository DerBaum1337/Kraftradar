---
import Hauptlayout from '../layouts/Hauptlayout.astro';
import Seitenkopf from '../components/Seitenkopf.astro';
---

<Hauptlayout
	title="Testmethode | KraftRadar"
	description="So bewertet KraftRadar Supplements und Gym-Zubehör nachvollziehbar und transparent."
>
	<Seitenkopf
		eyebrow="Transparenz"
		title="So testet KraftRadar."
		description="Bewertungen sollen nachvollziehbar sein. Deshalb werden Kriterien, Testzeitraum und mögliche Einschränkungen bei jedem Test offengelegt."
	/>

	<section class="section-alternate">
		<p class="eyebrow">Bewertung</p>
		<h2>Feste Kriterien statt Bauchgefühl</h2>

		<div class="method-grid">
			<article class="card method-card">
				<span class="badge">Supplements</span>
				<h3>Was bewertet wird</h3>
				<ul>
					<li>Geschmack und Löslichkeit</li>
					<li>Zutaten und Nährwerte</li>
					<li>Verpackung und praktische Nutzung</li>
					<li>Preis pro Portion</li>
					<li>Preis pro 25 Gramm Eiweiß, wenn relevant</li>
					<li>Vor- und Nachteile</li>
				</ul>
			</article>

			<article class="card method-card">
				<span class="badge">Gym-Zubehör</span>
				<h3>Was bewertet wird</h3>
				<ul>
					<li>Verarbeitung und Haltbarkeit</li>
					<li>Komfort und Handhabung</li>
					<li>Nutzen im Trainingsalltag</li>
					<li>Preis-Leistung</li>
					<li>Vor- und Nachteile</li>
				</ul>
			</article>
		</div>
	</section>

	<section class="prose-section">
		<div class="prose-content">
			<h2>So bleibt ein Test transparent</h2>
			<ul class="check-list">
				<li>Testdatum und betrachteter Preis werden genannt.</li>
				<li>Kostenlose Produkte oder Kooperationen werden offengelegt.</li>
				<li>Subjektive Eindrücke werden als solche gekennzeichnet.</li>
				<li>Gesundheitsversprechen werden nicht aus Werbung übernommen.</li>
				<li>Fehler und veraltete Angaben werden sichtbar korrigiert.</li>
			</ul>
		</div>
	</section>
</Hauptlayout>
