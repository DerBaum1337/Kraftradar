---
import Hauptlayout from '../layouts/Hauptlayout.astro';
import Seitenkopf from '../components/Seitenkopf.astro';
import Themenkarte from '../components/Themenkarte.astro';
import Artikelkarte from '../components/Artikelkarte.astro';
import { getCollection } from 'astro:content';

const themen = [
	{
		bereich: 'Grundlagen',
		symbol: 'GL',
		status: 'In Vorbereitung',
		titel: 'Trainingsgrundlagen',
		beschreibung: 'Trainingspläne, Wiederholungen, Belastungssteuerung und die wichtigsten Begriffe verständlich erklärt.',
	},
	{
		bereich: 'Krafttraining',
		symbol: 'KT',
		status: 'In Vorbereitung',
		titel: 'Kraft gezielt aufbauen',
		beschreibung: 'Übungen, saubere Ausführung und sinnvolle Prinzipien für langfristige Fortschritte.',
	},
	{
		bereich: 'Geräte',
		symbol: 'GT',
		status: 'In Vorbereitung',
		titel: 'Geräte und Technik',
		beschreibung: 'Erfahrungen mit Einstellungen, Bewegungsabläufen und dem sinnvollen Einsatz von Trainingsgeräten.',
	},
	{
		bereich: 'Ausdauer',
		symbol: 'AU',
		status: 'In Vorbereitung',
		titel: 'Ausdauer ergänzen',
		beschreibung: 'Wie Cardio neben Krafttraining sinnvoll eingesetzt werden kann, ohne den Fokus zu verlieren.',
	},
	{
		bereich: 'Regeneration',
		symbol: 'RG',
		status: 'In Vorbereitung',
		titel: 'Erholung ernst nehmen',
		beschreibung: 'Pausen, Schlaf und Belastungsmanagement als Teil eines nachhaltigen Trainingsalltags.',
	},
	{
		bereich: 'Dokumentation',
		symbol: 'FD',
		titel: 'Fortschritt festhalten',
		beschreibung: 'Welche Angaben einen Trainingsverlauf wirklich vergleichbar und nachvollziehbar machen.',
		href: '/training/fortschritt-dokumentieren',
		linkText: 'Artikel lesen',
	},
];

const beitraege = (await getCollection(
	'artikel',
	({ data }) => data.category === 'training' && !data.draft,
)).sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<Hauptlayout
	title="Training | KraftRadar"
	description="Trainingserfahrungen, Ganzkörper-Fokus und Grundlagen für echten Muskelaufbau."
>
	<Seitenkopf
		eyebrow="Training"
		title="Training verständlich aufbauen."
		description="Grundlagen, Geräteerfahrungen und nachvollziehbare Trainingsmethoden – mit Fokus auf saubere Fortschritte statt kurzfristigen Hype."
	/>

	<section class="section-alternate">
		<p class="eyebrow">Themenübersicht</p>
		<h2>Training, das zu deinem Alltag passt.</h2>
		<p class="section-intro">
			Hier entstehen allgemeine Ratgeber und Erfahrungen. Persönliche Werte und
			Zwischenstände findest du getrennt im Bereich „Mein Weg“.
		</p>

		<div class="card-grid">
			{themen.map((thema) => <Themenkarte {...thema} />)}
		</div>
	</section>

	{
		beitraege.length > 0 && (
			<section>
				<p class="eyebrow">Aktuelle Beiträge</p>
				<h2>Neu bei Training</h2>
				<div class="card-grid">
					{beitraege.map((beitrag) => (
						<Artikelkarte
							href={`/${beitrag.data.category}/${beitrag.id}`}
							category={beitrag.data.categoryLabel}
							title={beitrag.data.title}
							description={beitrag.data.description}
							linkLabel="Artikel lesen"
						/>
					))}
				</div>
			</section>
		)
	}
</Hauptlayout>
