---
import Hauptlayout from '../layouts/Hauptlayout.astro';
import Seitenkopf from '../components/Seitenkopf.astro';
import Bereichsbeitraege from '../components/Bereichsbeitraege.astro';
import Beitragsuebersicht from '../components/Beitragsuebersicht.astro';
---

<Hauptlayout
	title="Training | KraftRadar"
	description="Trainingserfahrungen, Ganzkörper-Fokus und Grundlagen für echten Muskelaufbau."
>
	<Seitenkopf
		eyebrow="Training"
		title="Training verständlich aufbauen."
		description="Grundlagen, Geräteerfahrungen und Trainingsmethoden verständlich erklärt – mit Fokus auf saubere Ausführung und langfristigen Fortschritt statt kurzfristigen Hype."
	/>

	<Bereichsbeitraege category="training" heading="Neu bei Training" limit={3} />

	<Beitragsuebersicht
		category="training"
		heading="Alle Beiträge zu Training"
		description="Alle veröffentlichten Ratgeber und Erfahrungen aus dem Trainingsbereich in einer kompakten Übersicht."
	/>
</Hauptlayout>
