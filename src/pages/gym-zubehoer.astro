---
import Hauptlayout from '../layouts/Hauptlayout.astro';
import Seitenkopf from '../components/Seitenkopf.astro';
import Themenkarte from '../components/Themenkarte.astro';
import Bereichsbeitraege from '../components/Bereichsbeitraege.astro';
import Beitragsuebersicht from '../components/Beitragsuebersicht.astro';
import { getArticlesByCategory } from '../lib/artikel';

const beitraege = await getArticlesByCategory('gym-zubehoer');
const zeigtVollstaendigeUebersicht = beitraege.length >= 7;

const themen = [
	{
		bereich: 'Schuhe',
		symbol: 'SH',
		status: 'In Vorbereitung',
		titel: 'Trainingsschuhe',
		beschreibung: 'Halt, Komfort und Alltagstauglichkeit für verschiedene Arten von Training.',
	},
	{
		bereich: 'Technik',
		symbol: 'FU',
		status: 'In Vorbereitung',
		titel: 'Fitnessuhren',
		beschreibung: 'Tracking-Funktionen und praktische Nutzung im Gym statt bloßer Datenblätter.',
	},
	{
		bereich: 'Audio',
		symbol: 'KH',
		status: 'In Vorbereitung',
		titel: 'Kopfhörer',
		beschreibung: 'Sitz, Haltbarkeit und Bedienung unter echten Trainingsbedingungen.',
	},
	{
		bereich: 'Organisation',
		symbol: 'TS',
		status: 'In Vorbereitung',
		titel: 'Taschen und Rucksäcke',
		beschreibung: 'Stauraum, Verarbeitung und sinnvolle Details für den Weg zum Training.',
	},
	{
		bereich: 'Alltag',
		symbol: 'ST',
		status: 'In Vorbereitung',
		titel: 'Shaker und Trinkflaschen',
		beschreibung: 'Dichtigkeit, Reinigung und Nutzen im täglichen Einsatz.',
	},
	{
		bereich: 'Griffkraft',
		symbol: 'GH',
		status: 'In Vorbereitung',
		titel: 'Griffe und Zughilfen',
		beschreibung: 'Komfort, Material und der tatsächliche Mehrwert bei Zugübungen.',
	},
];
---

<Hauptlayout
	title="Gym-Zubehör | KraftRadar"
	description="Sinnvolles Gym-Zubehör auf Preis-Leistung und Praxisnutzen geprüft."
	noindex={beitraege.length === 0}
>
	<Seitenkopf
		eyebrow="Gym-Zubehör"
		title="Ausrüstung für den Praxiseinsatz."
		description="Schuhe, Taschen, Griffe und Technik werden danach eingeordnet, wie gut sie sich im Trainingsalltag wirklich bewähren."
	/>

	{
		!zeigtVollstaendigeUebersicht && (
			<Bereichsbeitraege category="gym-zubehoer" heading="Beiträge zu Gym-Zubehör" />
		)
	}
	{
		zeigtVollstaendigeUebersicht && (
			<Bereichsbeitraege category="gym-zubehoer" heading="Neu bei Gym-Zubehör" limit={3} />
		)
	}

	<section class="section-alternate">
		<p class="eyebrow">Themenübersicht</p>
		<h2>Zubehör, das im Alltag bestehen muss.</h2>
		<p class="section-intro">
			KraftRadar befindet sich hier noch im Aufbau. Erste Praxistests erscheinen nach
			einem nachvollziehbar dokumentierten Testzeitraum mit Preisstand und Nutzungserfahrung.
		</p>

		<div class="card-grid topic-grid">
			{themen.map((thema) => <Themenkarte {...thema} />)}
		</div>
	</section>

	{
		zeigtVollstaendigeUebersicht && (
			<Beitragsuebersicht
				category="gym-zubehoer"
				heading="Alle Beiträge zu Gym-Zubehör"
				description="Alle veröffentlichten Praxistests und Erfahrungen in einer kompakten Übersicht."
			/>
		)
	}
</Hauptlayout>
