---
import Hauptlayout from '../layouts/Hauptlayout.astro';
import Seitenkopf from '../components/Seitenkopf.astro';
import Bereichsbeitraege from '../components/Bereichsbeitraege.astro';
import Beitragsuebersicht from '../components/Beitragsuebersicht.astro';
import { getArticlesByCategory } from '../lib/artikel';

const beitraege = await getArticlesByCategory('supplements');
---

<Hauptlayout
	title="Supplements | KraftRadar"
	description="Ehrliche Tests zu Whey, Kreatin und Co. – Fokus auf echtes Preis-Leistungs-Verhältnis."
	noindex={beitraege.length === 0}
>
	<Seitenkopf
		eyebrow="Supplements"
		title="Produkte nüchtern betrachtet."
		description="Verständliche Einordnungen und Praxistests zu Proteinpulver, Kreatin und weiteren Supplements – transparent, alltagstauglich und mit Blick auf Preis-Leistung."
	/>

	<Bereichsbeitraege category="supplements" heading="Neu bei Supplements" limit={3} />

	<Beitragsuebersicht
		category="supplements"
		heading="Alle Beiträge zu Supplements"
		description="Alle veröffentlichten Tests, Erfahrungen und Vergleiche in einer kompakten Übersicht."
	/>
</Hauptlayout>
