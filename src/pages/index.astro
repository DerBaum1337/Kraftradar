---
import Hauptlayout from '../layouts/Hauptlayout.astro';
import RadarVisual from '../components/RadarVisual.astro';
import Vertrauensleiste from '../components/Vertrauensleiste.astro';
import Artikelkarte from '../components/Artikelkarte.astro';
import KategorieIcon from '../components/KategorieIcon.astro';
import { getLatestArticles } from '../lib/artikel';

const neuesteInhalte = await getLatestArticles(3);
---

<Hauptlayout
	title="KraftRadar – EGYM, Training und Gym-Produkte ehrlich eingeordnet"
	description="Persönliche EGYM-Erfahrungen, verständliche Trainingsartikel und transparente Einordnungen zu Supplements und Gym-Zubehör."
>
	<section class="hero">
		<div class="hero-copy">
			<p class="eyebrow">KraftRadar</p>

			<h1>Was sich im Gym wirklich lohnt.</h1>

			<p>
				Persönliche Erfahrungen, verständliche Einordnungen und später ausführliche
				Praxistests zu Training, Supplements und Gym-Zubehör.
			</p>

			<div class="hero-actions">
				<a class="button" href="#bereiche">Bereiche entdecken</a>
				<a class="button button--secondary" href="/mein-weg">Meinen Weg ansehen</a>
			</div>
		</div>

		<RadarVisual />
	</section>

	<Vertrauensleiste />

	<section id="bereiche" class="category-section">
		<p>Bereiche</p>
		<h2>Was dich bei KraftRadar erwartet</h2>
		<p class="section-intro">
			Praxisnahe Inhalte, verständliche Vergleiche und persönliche Erfahrungen –
			ohne unnötigen Hype.
		</p>

		<div class="card-grid">
			<a class="card category-card" href="/training">
				<div class="category-card-header">
					<KategorieIcon type="training" />
					<span class="badge">Training</span>
				</div>
				<h3>Stärker trainieren</h3>
				<p>
					Grundlagen, Erfahrungen und verständliche Trainingsthemen für deinen
					Fortschritt.
				</p>
				<span class="card-link">Training entdecken <span aria-hidden="true">→</span></span>
			</a>

			<a class="card category-card" href="/supplements">
				<div class="category-card-header">
					<KategorieIcon type="supplements" />
					<span class="badge">Supplements</span>
				</div>
				<h3>Produkte ehrlich vergleichen</h3>
				<p>
					Inhaltsstoffe, Preise und praktische Erfahrungen klar und nachvollziehbar
					bewertet.
				</p>
				<span class="card-link">Supplements ansehen <span aria-hidden="true">→</span></span>
			</a>

			<a class="card category-card" href="/gym-zubehoer">
				<div class="category-card-header">
					<KategorieIcon type="zubehoer" />
					<span class="badge">Gym-Zubehör</span>
				</div>
				<h3>Ausrüstung im Praxiseinsatz</h3>
				<p>
					Schuhe, Zubehör und Technik mit Blick auf Nutzen, Qualität und
					Preis-Leistung.
				</p>
				<span class="card-link">Zubehör entdecken <span aria-hidden="true">→</span></span>
			</a>
		</div>
	</section>

	{
		neuesteInhalte.length > 0 && (
			<section class="section-alternate current-section">
				<p class="eyebrow">Aktuell bei KraftRadar</p>
				<h2>Die neuesten Inhalte</h2>
				<p class="section-intro">
					Neue veröffentlichte Artikel erscheinen hier automatisch – unabhängig davon,
					ob sie sich um Training, Supplements, Gym-Zubehör oder meinen Weg drehen.
				</p>

				<div class="card-grid">
					{neuesteInhalte.map((inhalt) => (
						<Artikelkarte
							href={`/${inhalt.data.category}/${inhalt.id}`}
							category={inhalt.data.categoryLabel}
							title={inhalt.data.title}
							description={inhalt.data.description}
							image={inhalt.data.image}
							imageAlt={inhalt.data.imageAlt}
							publishedAt={inhalt.data.publishedAt}
							estimatedReadingMinutes={inhalt.data.estimatedReadingMinutes}
							linkLabel="Artikel lesen"
						/>
					))}
				</div>
			</section>
		)
	}

	<section class="journey-section">
		<div class="journey-copy">
			<p class="eyebrow">Mein Weg</p>
			<h2>Fortschritt ohne Hochglanzfilter.</h2>
			<p>
				Ich dokumentiere meinen Weg im Gym mit ehrlichen Zwischenständen. Dazu gehören
				Fortschritte genauso wie Anfängerfehler und Dinge, die nicht funktioniert
				haben.
			</p>
			<a class="button button--secondary" href="/mein-weg">Zur persönlichen Dokumentation</a>
		</div>

		<div class="journey-principles" aria-label="Grundsätze der Dokumentation">
			<div class="mini-stat">
				<span>01</span>
				<strong>Regelmäßig festhalten</strong>
			</div>
			<div class="mini-stat">
				<span>02</span>
				<strong>Fehler offen benennen</strong>
			</div>
			<div class="mini-stat">
				<span>03</span>
				<strong>Erkenntnisse einordnen</strong>
			</div>
		</div>
	</section>

	<section class="about-teaser section-alternate">
		<div>
			<p class="eyebrow">Warum KraftRadar?</p>
			<h2>Eine unabhängige Orientierung für den Gym-Alltag.</h2>
		</div>
		<div>
			<p>
				KraftRadar entsteht als persönliches, transparentes Projekt. Herstellertexte
				werden nicht einfach übernommen, und Werbung soll klar erkennbar bleiben.
			</p>
			<a class="text-link" href="/ueber-kraftradar">Mehr über KraftRadar <span aria-hidden="true">→</span></a>
		</div>
	</section>
</Hauptlayout>
