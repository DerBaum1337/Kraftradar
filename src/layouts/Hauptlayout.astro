---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	noindex?: boolean;
}

const {
	title = 'KraftRadar',
	description = 'KraftRadar – ehrliche Inhalte über Gym, Training, Supplements, Zubehör und persönlichen Fortschritt.',
	image = '/og-kraftradar.png',
	noindex = false,
} = Astro.props;

const pageTitle =
	title === 'KraftRadar' || title.endsWith(' | KraftRadar')
		? title
		: `${title} | KraftRadar`;

const siteURL = Astro.site ?? new URL('https://kraftradar.de');
const canonicalURL = new URL(Astro.url.pathname, siteURL);
const imageURL = new URL(image, siteURL);
const robots = noindex ? 'noindex, nofollow' : 'index, follow';

const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'WebPage',
	name: pageTitle,
	description,
	url: canonicalURL.href,
	inLanguage: 'de-DE',
	isPartOf: {
		'@type': 'WebSite',
		name: 'KraftRadar',
		url: siteURL.href,
	},
};
---

<!doctype html>
<html lang="de">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#111720" />

		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<meta name="robots" content={robots} />
		<link rel="canonical" href={canonicalURL} />

		<meta property="og:type" content="website" />
		<meta property="og:locale" content="de_DE" />
		<meta property="og:site_name" content="KraftRadar" />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:image" content={imageURL} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="KraftRadar – ehrliche Tests und Vergleiche rund ums Gym" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageURL} />

		<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	</head>

	<body>
		<a class="skip-link" href="#hauptinhalt">Zum Inhalt springen</a>
		<Header />

		<main id="hauptinhalt" tabindex="-1">
			<slot />
		</main>

		<Footer />
	</body>
</html>
