---
import { getEntry, type CollectionEntry } from 'astro:content';
import type { Artikel } from '../lib/artikel';
import Artikelkarte from '../components/Artikelkarte.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Hauptlayout from './Hauptlayout.astro';
import Inhaltsverzeichnis from '../components/Inhaltsverzeichnis.astro';
import Quellenliste from '../components/Quellenliste.astro';
import { lesezeitInMinuten } from '../lib/lesezeit';

interface Props {
	entry: CollectionEntry<'articles'>;
	relatedArticles?: Artikel[];
	headings: Array<{
		depth: number;
		slug: string;
		text: string;
	}>;
}

const { entry, headings, relatedArticles = [] } = Astro.props;
const { data } = entry;
const author = await getEntry('authors', data.author);
const authorName = author?.data.name ?? data.author;
const siteURL = Astro.site ?? new URL('https://kraftradar.de');
const articleURL = new URL(`/${data.category}/${data.slug}/`, siteURL);
const categoryURL = new URL(`/${data.category}/`, siteURL);
const publishedAt = data.publishedAt?.toISOString();
const updatedAt = data.updatedAt?.toISOString();
const socialImage = data.seo.ogImage || data.heroImage?.src;
const readingMinutes = lesezeitInMinuten(entry.body ?? '');
const categoryLinkLabels: Record<string, string> = {
	training: 'Alle Beiträge zu Training ansehen',
	supplements: 'Alle Beiträge zu Supplements ansehen',
	'gym-zubehoer': 'Alle Beiträge zu Gym-Zubehör ansehen',
	'mein-weg': 'Alle Beiträge zu meinem Weg ansehen',
};

const articleStructuredData = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'Article',
			headline: data.title,
			description: data.description,
			...(publishedAt ? { datePublished: publishedAt } : {}),
			...(updatedAt ? { dateModified: updatedAt } : {}),
			author: {
				'@type': 'Person',
				name: authorName,
				url: new URL(`/autoren/${data.author}/`, siteURL).href,
			},
			publisher: {
				'@type': 'Organization',
				name: 'KraftRadar',
				url: siteURL.href,
			},
			...(socialImage ? { image: new URL(socialImage, siteURL).href } : {}),
			mainEntityOfPage: articleURL.href,
			inLanguage: 'de-DE',
		},
		{
			'@type': 'BreadcrumbList',
			itemListElement: [
				{ '@type': 'ListItem', position: 1, name: 'Start', item: siteURL.href },
				{
					'@type': 'ListItem',
					position: 2,
					name: data.categoryLabel.split(' · ')[0],
					item: categoryURL.href,
				},
				{ '@type': 'ListItem', position: 3, name: data.title, item: articleURL.href },
			],
		},
	],
};
---

<Hauptlayout
	title={data.seo.title}
	description={data.seo.description}
	image={socialImage}
	imageAlt={data.heroImage?.alt}
	canonical={data.seo.canonical || undefined}
	noindex={data.noindex}
	structuredData={articleStructuredData}
	ogType="article"
	articlePublishedTime={publishedAt}
	articleModifiedTime={updatedAt}
>
	<article class="article-page">
		<Breadcrumbs category={data.category} categoryLabel={data.categoryLabel} title={data.title} />
		<header class="article-header">
			<p class="eyebrow">{data.categoryLabel}</p>
			<h1>{data.title}</h1>
			<p>{data.description}</p>
			<div class="article-meta">
				{data.publishedAt && <time datetime={publishedAt}>Veröffentlicht: {data.publishedAt.toLocaleDateString('de-DE')}</time>}
				{data.updatedAt && <time datetime={updatedAt}>Aktualisiert: {data.updatedAt.toLocaleDateString('de-DE')}</time>}
				<span>{readingMinutes} Min. Lesezeit</span>
				<span>Von <a class="article-author" href={`/autoren/${data.author}/`}>{authorName}</a></span>
			</div>
		</header>

		{data.toc && <Inhaltsverzeichnis headings={headings} />}

		<div class="article-body">
			{
				data.heroImage && (
					<figure class="article-hero-figure">
						<img class="article-hero-image" src={data.heroImage.src} alt={data.heroImage.alt} width="1600" height="900" />
						{(data.heroImage.caption || data.heroImage.credit) && (
							<figcaption>
								{data.heroImage.caption}
								{data.heroImage.credit && ` · ${data.heroImage.credit}`}
							</figcaption>
						)}
					</figure>
				)
			}
			<slot />
			<Quellenliste sources={data.sources} />
		</div>

		{
			relatedArticles.length > 0 && (
				<section class="article-related" aria-label="Passende Beiträge">
					<p class="eyebrow">Weiterlesen</p>
					<h2>Passende Beiträge</h2>
					<div class="article-related-grid">
						{relatedArticles.map((article) => (
							<Artikelkarte
								href={`/${article.data.category}/${article.data.slug}`}
								category={article.data.categoryLabel}
								title={article.data.title}
								description={article.data.excerpt}
								publishedAt={article.data.publishedAt}
								estimatedReadingMinutes={lesezeitInMinuten(article.body ?? '')}
								linkLabel="Artikel lesen"
							/>
						))}
					</div>
					<div class="article-related-actions">
						<a class="article-related-link" href={`/${data.category}/`}>{categoryLinkLabels[data.category]}</a>
						<a class="article-related-link article-related-link--muted" href="/impressum/">Fehler oder veraltete Information melden</a>
					</div>
				</section>
			)
		}
	</article>
</Hauptlayout>
