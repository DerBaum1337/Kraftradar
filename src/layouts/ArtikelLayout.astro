---
import type { CollectionEntry } from 'astro:content';
import type { Artikel } from '../lib/artikel';
import Artikelkarte from '../components/Artikelkarte.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Bewertungsbox from '../components/Bewertungsbox.astro';
import Hauptlayout from './Hauptlayout.astro';
import Inhaltsverzeichnis from '../components/Inhaltsverzeichnis.astro';
import Produktdaten from '../components/Produktdaten.astro';
import Transparenzhinweis from '../components/Transparenzhinweis.astro';
import VorNachteile from '../components/VorNachteile.astro';

interface Props {
	entry: CollectionEntry<'artikel'>;
	relatedArticles?: Artikel[];
	headings: Array<{
		depth: number;
		slug: string;
		text: string;
	}>;
}

const { entry, headings, relatedArticles = [] } = Astro.props;
const { data, id } = entry;
const siteURL = Astro.site ?? new URL('https://kraftradar.de');
const articleURL = new URL(`/${data.category}/${id}/`, siteURL);
const categoryURL = new URL(`/${data.category}/`, siteURL);
const publishedAt = data.publishedAt.toISOString();
const updatedAt = data.updatedAt?.toISOString();
const socialImage = data.ogImage ?? data.image;
const categoryLinkLabels: Record<string, string> = {
	training: 'Alle Beiträge zu Training ansehen',
	supplements: 'Alle Beiträge zu Supplements ansehen',
	'gym-zubehoer': 'Alle Beiträge zu Gym-Zubehör ansehen',
	'mein-weg': 'Alle Beiträge zu meinem Weg ansehen',
};

const articleStructuredData = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'Article',
			headline: data.title,
			description: data.description,
			datePublished: publishedAt,
			...(updatedAt ? { dateModified: updatedAt } : {}),
			author: {
				'@type': 'Person',
				name: data.author,
				url: new URL('/ueber-kraftradar/', siteURL).href,
			},
			publisher: {
				'@type': 'Organization',
				name: 'KraftRadar',
				url: siteURL.href,
			},
			...(socialImage ? { image: new URL(socialImage, siteURL).href } : {}),
			mainEntityOfPage: articleURL.href,
			inLanguage: 'de-DE',
		},
		{
			'@type': 'BreadcrumbList',
			itemListElement: [
				{ '@type': 'ListItem', position: 1, name: 'Start', item: siteURL.href },
				{
					'@type': 'ListItem',
					position: 2,
					name: data.categoryLabel.split(' · ')[0],
					item: categoryURL.href,
				},
				{ '@type': 'ListItem', position: 3, name: data.title, item: articleURL.href },
			],
		},
	],
};
---

<Hauptlayout
	title={`${data.title} | KraftRadar`}
	description={data.description}
	image={socialImage}
	imageAlt={data.imageAlt}
	structuredData={articleStructuredData}
	ogType="article"
	articlePublishedTime={publishedAt}
	articleModifiedTime={updatedAt}
>
	<article class="article-page">
		<Breadcrumbs category={data.category} categoryLabel={data.categoryLabel} title={data.title} />
		<header class="article-header">
			<p class="eyebrow">{data.categoryLabel}</p>
			<h1>{data.title}</h1>
			<p>{data.description}</p>
			<div class="article-meta">
				<time datetime={publishedAt}>Veröffentlicht: {data.publishedAt.toLocaleDateString('de-DE')}</time>
				{data.updatedAt && <time datetime={updatedAt}>Aktualisiert: {data.updatedAt.toLocaleDateString('de-DE')}</time>}
				<span>{data.estimatedReadingMinutes} Min. Lesezeit</span>
				<span>Von <a class="article-author" href="/ueber-kraftradar/">{data.author}</a></span>
			</div>
		</header>

		<Inhaltsverzeichnis headings={headings} />

		<div class="article-body">
			{data.image && <img class="article-hero-image" src={data.image} alt={data.imageAlt ?? ''} />}
			{data.transparency && <Transparenzhinweis {...data.transparency} />}
			{data.productData && <Produktdaten items={data.productData} />}
			{data.pros && data.cons && <VorNachteile vorteile={data.pros} nachteile={data.cons} />}
			{data.ratings && data.overallScore !== undefined && <Bewertungsbox ratings={data.ratings} overallScore={data.overallScore} />}
			<slot />
		</div>

		{
			relatedArticles.length > 0 && (
				<section class="article-related" aria-label="Passende Beiträge">
					<p class="eyebrow">Weiterlesen</p>
					<h2>Passende Beiträge</h2>
					<div class="article-related-grid">
						{relatedArticles.map((article) => (
							<Artikelkarte
								href={`/${article.data.category}/${article.id}`}
								category={article.data.categoryLabel}
								title={article.data.title}
								description={article.data.description}
								publishedAt={article.data.publishedAt}
								estimatedReadingMinutes={article.data.estimatedReadingMinutes}
								linkLabel="Artikel lesen"
							/>
						))}
					</div>
					<div class="article-related-actions">
						<a class="article-related-link" href={`/${data.category}/`}>{categoryLinkLabels[data.category]}</a>
						<a class="article-related-link article-related-link--muted" href="/impressum/">Fehler oder veraltete Information melden</a>
					</div>
				</section>
			)
		}
	</article>
</Hauptlayout>
