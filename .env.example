# Diese Datei enthält nur Beispielwerte und darf eingecheckt werden.
# Lege lokal eine Datei namens .env mit deinen echten Angaben an.
# Hinterlege dieselben Variablen vor dem Deployment in Cloudflare Pages.

LEGAL_OWNER_NAME="Max Mustermann"
LEGAL_STREET_AND_NUMBER="Musterstraße 1"
LEGAL_POSTAL_CODE_AND_CITY="12345 Musterstadt"
LEGAL_EMAIL="kontakt@example.de"

# Nur für den separat bereitgestellten OAuth-Worker. Niemals echte Werte committen.
GITHUB_OAUTH_CLIENT_ID="<DEINE_GITHUB_CLIENT_ID>"
GITHUB_OAUTH_CLIENT_SECRET="<DEIN_GITHUB_CLIENT_SECRET>"
OAUTH_ALLOWED_ORIGIN="https://kraftradar.de"
